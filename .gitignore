# --- Virtual Environments (VITAL) ---
# Evita que el agente indexe miles de archivos de librerías
.venv/
venv/
env/
ENV/

# --- Antigravity & Agent Ops (Protocolo v2.6) ---
.agent/
.claude/
skill_sync.py
# Logs generados por la mitigación de "Terminal Blindness"
*.log
# Archivos de memoria temporal o scratchpads
temp_*.txt
output_log.txt

# --- Security & Secrets ---
.env
.env.local
.env.*.local
# Mantén .env.example para referencia del agente
!.env.example
# Script de pruebas con credenciales hardcodeadas
webapp/probe_api.js
# Assets APK Android — solo referencia local
samples/
# Notas internas
mejoras_01.md

